{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TwoPixel V2",
  "version": "0.1.0",
  "identifier": "com.twopixel.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TwoPixel V2",
        "width": 1360,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/twopixel-backend"
    ]
  }
}
